    <!-- Expertise for saving throws-->
    <element name="Saving Throw Expertise (Strength)" type="Proficiency" source="Faleria Essentials" id="ID_PROFICIENCY_SAVINGTHROW_EXPERTISE_STRENGTH">
		<supports>Saving Throw Expertise</supports>
        <requirements>ID_PROFICIENCY_SAVINGTHROW_STRENGTH</requirements>
        <description>
            <p>Your proficiency bonus is doubled for any Strength Saving Throw you make.</p>
            <div class="reference">
                <div element="ID_PROFICIENCY_SAVINGTHROW_STRENGTH" />
            </div>
        </description>
        <sheet display="false" />
		<rules>
			<stat name="strength:save:proficiency" value="proficiency" bonus="double"/>
		</rules>
	</element>

