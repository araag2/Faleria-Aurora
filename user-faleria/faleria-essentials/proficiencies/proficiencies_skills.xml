    <!-- Skill Expertises -->
	<element name="Skill Expertise (Acrobatics)" type="Proficiency" source="Faleria Essentials" id="ID_PROFICIENCY_SKILL_EXPERTISE_ACROBATICS">
		<supports>Expertise, Skill Expertise, ID_SUPPORT_EXPERTISE</supports>
		<requirements>ID_PROFICIENCY_SKILL_ACROBATICS</requirements>
		<description>
			<p>Your proficiency bonus is doubled for any Acrobatics check you make.</p>
			<div class="reference">
				<div element="ID_PROFICIENCY_SKILL_ACROBATICS" />
			</div>
		</description>
