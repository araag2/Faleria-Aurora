	<element name="Strength +1" type="Ability Score Improvement" source="Internal" id="ID_INTERNAL_ABILITY_SCORE_IMPROVEMENT_FEAT_STRENGTH">
		<supports>Feat Ability Score Increase</supports>
		<description>
			<p>Your Strength increases by 1.</p>
		</description>
