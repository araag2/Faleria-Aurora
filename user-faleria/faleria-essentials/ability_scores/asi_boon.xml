	<!-- Generic Ability Score Increase for Boons from PHB24 and onward -->
	<element name="Strength +1" type="Ability Score Improvement" source="Internal" id="ID_INTERNAL_ABILITY_SCORE_IMPROVEMENT_BOON_STRENGTH">
		<supports>Boon Ability Score Increase</supports>
		<description>
			<p>Your Strength increases by 1, to a maximum of 30.</p>
		</description>
		<setters>
			<set name="allow duplicate">true</set>
		</setters>
		<rules>
			<stat name="strength" value="1" alt="Ability Score Increase" />
			<stat name="strength:max:extra" value="10" bonus="base" />
		</rules>
	</element>
