<?xml version="1.0" encoding="utf-8" ?>
<elements>
	<info>
		<name>ASI Background Combinations (5e 2024)</name>
		<update version="0.0.1">
			<file name="asi_background_combinations.xml" url="https://raw.githubusercontent.com/araag2/Faleria-Aurora/master/user-faleria/faleria-essentials/ability_scores/asi_background_combinations.xml" />
		</update>
	</info>

	<!-- 5e 2024: ASI Combinations elements for Backgrounds -->
	<element name="Strength, Dexterity, Constitution" type="Ability Score Improvement" source="Internal" id="ID_INTERNAL_ABILITY_SCORE_IMPROVEMENT_COMBINATION_STR_DEX_CON">
		<supports>Custom Background Ability Score Combination</supports>
		<description>
			<p>You can increase Strength, Dexterity, or Constitution score by 2 and another one by 1, or increase all three by 1. None of these increases can raise a score above 20.</p>
		</description>
		<sheet display="false" />
		<rules>
			<select type="Ability Score Improvement" name="Ability Score Improvement Option" supports="ID_INTERNAL_ABILITY_SCORE_IMPROVEMENT_COMBINATION_STR_DEX_CON_1|ID_INTERNAL_ABILITY_SCORE_IMPROVEMENT_COMBINATION_STR_DEX_CON_2" />
		</rules>
	</element>
	<element name="Ability Score Improvement +2, +1" type="Ability Score Improvement" source="Internal" id="ID_INTERNAL_ABILITY_SCORE_IMPROVEMENT_COMBINATION_STR_DEX_CON_1">
		<description>
			<p>You can increase Strength, Dexterity, or Constitution score by 2 and increase a different score by 1.</p>
		</description>
		<sheet display="false" />
		<rules>
			<select type="Ability Score Improvement" name="Background Ability Score Improvement +2" supports="ID_WOTC_TCOE_OPTION_CUSTOMIZED_ASI_STRENGTH_INCREASE_2|ID_WOTC_TCOE_OPTION_CUSTOMIZED_ASI_DEXTERITY_INCREASE_2|ID_WOTC_TCOE_OPTION_CUSTOMIZED_ASI_CONSTITUTION_INCREASE_2" />
			<select type="Ability Score Improvement" name="Background Ability Score Improvement +1" supports="ID_WOTC_TCOE_OPTION_CUSTOMIZED_ASI_STRENGTH_INCREASE_1|ID_WOTC_TCOE_OPTION_CUSTOMIZED_ASI_DEXTERITY_INCREASE_1|ID_WOTC_TCOE_OPTION_CUSTOMIZED_ASI_CONSTITUTION_INCREASE_1" />
		</rules>
	</element>
	<element name="Ability Score Improvement +1, +1, +1" type="Ability Score Improvement" source="Internal" id="ID_INTERNAL_ABILITY_SCORE_IMPROVEMENT_COMBINATION_STR_DEX_CON_2">
		<description>
			<p>You increase Strength, Dexterity, and Constitution score by 1.</p>
		</description>
		<sheet display="false" />
		<rules>
			<stat name="strength" value="1" alt="Ability Score Increase (Background)" />
			<stat name="dexterity" value="1" alt="Ability Score Increase (Background)" />
			<stat name="constitution" value="1" alt="Ability Score Increase (Background)" />
		</rules>
	</element>

