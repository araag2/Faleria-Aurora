    <!-- Available Creture Sizes -->
    <!-- TO:DO We can add more sizes as needed / description of what the size is and what it mecanically does-->
	<element name="Tiny" type="Racial Trait" source="Internal" id="ID_INTERNAL_RACIAL_TRAIT_TINY">
		<description>
			<p>Your size is Tiny.</p>
		</description>
		<sheet display="false" />
		<rules>
			<grant type="Size" id="ID_SIZE_TINY" />
		</rules>
	</element>

