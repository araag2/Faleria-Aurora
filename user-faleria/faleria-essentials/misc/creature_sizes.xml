	<!-- Speed Items -->
	<element name="Speed: Climb Equals Walking" type="Item" source="Internal" id="ID_INTERNAL_ITEM_CLIMB_WALKING">
		<description>
			<p><i>You can equip this item to "enable" it. It remains hidden from the inventory on your character sheet.</i></p>
			<p>You have a climbing speed equal to your walking speed.</p>
		</description>
		<setters>
			<set name="category">Additional Feature</set>
			<set name="slot">misc</set>
			<set name="inventory-hidden">true</set>
		</setters>
		<rules>
			<stat name="innate speed:climb" value="innate speed" bonus="base" />
		</rules>
	</element>

